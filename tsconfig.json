{
  "compilerOptions": {
    "isolatedModules": true,
    "target": "esnext",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/hooks/**/*",
    "src/scripts/utils/**/*",
    "cli-scripts/**/*",
    "src_OLD/**/*",
    "src/scripts/**/*",
    "src/hooks/hashes.ts",
    "src/hooks/members.ts",
    "src/scripts/fuzzy-dates.ts",
    "src/filters/testing-eligibility.test.ts"
  ],
  "exclude": ["node_modules", "build"]
}
