{
  "name": "usfbd-members",
  "version": "0.0.1",
  "private": true,
  "description": "Member pages for USFBD",
  "license": "MIT",
  "author": "Nelson Pecora <nelson@keats.me>",
  "repository": "https://github.com/nelsonpecora/usfbd-members.git",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "oxfmt && prettier --write \"**/*.astro\"",
    "format:check": "oxfmt --check && prettier --check \"**/*.astro\"",
    "lint": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "clean:members": "rimraf --glob src/members/*",
    "generate:info": "tsx cli-scripts/fetch-member-info.ts"
  },
  "dependencies": {
    "astro": "^6.1.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/pluralize": "^0.0.33",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "dotenv": "17.4.1",
    "google-auth-library": "^9.0.0",
    "google-spreadsheet": "5.2.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.44.0",
    "oxlint": "1.59.0",
    "pluralize": "^8.0.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
