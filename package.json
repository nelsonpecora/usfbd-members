{
  "name": "usfbd-members",
  "version": "0.0.1",
  "description": "Member pages for USFBD",
  "main": "index.js",
  "repository": "https://github.com/nelsonpecora/usfbd-members.git",
  "author": "Nelson Pecora <nelson@keats.me>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "clean": "rimraf build",
    "clean:members": "rimraf --glob src/data/members/*",
    "build": "eleventy",
    "dev": "yarn clean && eleventy --serve",
    "lint": "semistandard --verbose --fix | snazzy",
    "test": "jest",
    "generate:info": "node cli-scripts/fetch-member-info.js"
  },
  "semistandard": {
    "ignore": [
      "build/",
      "node_modules/"
    ],
    "globals": [
      "describe",
      "it",
      "expect"
    ]
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.5",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "dotenv": "17.4.1",
    "esbuild": "0.28.0",
    "google-auth-library": "^9.0.0",
    "google-spreadsheet": "5.2.0",
    "jest": "30.3.0",
    "js-yaml": "^4.1.1",
    "pluralize": "^8.0.0",
    "rimraf": "6.1.3",
    "semistandard": "17.0.0",
    "snazzy": "^9.0.0"
  },
  "dependencies": {}
}
