{
  "name": "usfbd-members",
  "version": "0.0.1",
  "private": true,
  "description": "Member pages for USFBD",
  "license": "MIT",
  "author": "Nelson Pecora <nelson@keats.me>",
  "repository": "https://github.com/nelsonpecora/usfbd-members.git",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf build",
    "clean:members": "rimraf --glob src/data/members/*",
    "build": "tsx node_modules/.bin/eleventy",
    "dev": "yarn clean && tsx node_modules/.bin/eleventy --serve",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "generate:info": "tsx cli-scripts/fetch-member-info.ts"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/pluralize": "^0.0.33",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "dotenv": "17.4.1",
    "esbuild": "0.28.0",
    "google-auth-library": "^9.0.0",
    "google-spreadsheet": "5.2.0",
    "js-yaml": "^4.1.1",
    "oxfmt": "^0.44.0",
    "oxlint": "1.59.0",
    "pluralize": "^8.0.0",
    "rimraf": "6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
